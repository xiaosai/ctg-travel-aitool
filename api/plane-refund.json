[
  {
    "method": "orderDeduct",
    "description": "机票订单核损（退票前必调）",
    "category": "ORDER",
    "subCategory": "COMMON",
    "action": "DEDUCT",
    "parameters": {
      "type": "object",
      "properties": {
        "orderBaseId": {
          "type": "string",
          "description": "订单编号"
        },
        "refundType": {
          "type": "integer",
          "description": "退款类型 1-整单退 2-部分退"
        },
        "passengerIds": {
          "type": "array",
          "description": "需要退票的乘客ID列表（部分退时必填）",
          "items": {
            "type": "Long"
          }
        }
      },
      "required": ["orderBaseId", "refundType"]
    }
  },
  {
    "method": "flight.refund",
    "description": "申请机票退票",
    "category": "ORDER",
    "subCategory": "FLIGHT",
    "action": "REFUND",
    "parameters": {
      "type": "object",
      "properties": {
        "orderBaseId": {
          "type": "string",
          "description": "订单号"
        },
        "orderType": {
          "type": "integer",
          "description": "订单类型 默认值0(机票)"
        },
        "applyType": {
          "type": "integer",
          "description": "申请类型，默认1"
        },
        "refundType": {
          "type": "integer",
          "description": "退票类型 1-全额退票（全退） 2-部分退票（部分乘客退）"
        },
        "amount": {
          "type": "number",
          "description": "退款金额"
        },
        "refundReason": {
          "type": "string",
          "description": "退票原因"
        },
        "reasonType": {
          "type": "integer",
          "description": "原因类型，默认0"
        },
        "memberId": {
          "type": "string",
          "description": "会员ID"
        },
        "originAmount": {
          "type": "number",
          "description": "原支付金额"
        },
        "refundItemList": {
          "type": "array",
          "description": "退票明细列表",
          "items": {
            "type": "object",
            "properties": {
              "orderItemNo": {
                "type": "string",
                "description": "订单项编号（order item no）"
              },
              "orderPassengerIds": {
                "type": "array",
                "description": "需要退票的乘客ID数组（必填）",
                "items": {
                  "type": "string"
                }
              },
              "refundQuantity": {
                "type": "integer",
                "description": "本次退票退几张票"
              },
              "refundAmount": {
                "type": "number",
                "description": "本次退票手续费"
              }
            },
            "required": ["orderItemNo", "orderPassengerIds", "refundQuantity"]
          }
        }
      },
      "required": ["orderBaseId", "orderType", "applyType", "refundType", "amount", "refundItemList"]
    }
  }
]
